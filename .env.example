# Copy this file to .env (same folder) and paste your real keys — .env is gitignored.
# Add lines with `Add-Content`, never `Set-Content`: the latter replaces the whole file
# and takes the other keys with it.

# Free key: create an account at https://three.arcprize.org — see notes/howto/01.
ARC_API_KEY=your-api-key-here

# Free key: https://aistudio.google.com/apikey — see notes/howto/02.
# The SDK also accepts GOOGLE_API_KEY, which wins if both are set.
GEMINI_API_KEY=your-gemini-key-here
